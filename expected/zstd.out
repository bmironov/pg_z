CREATE EXTENSION IF NOT EXISTS pg_z;
-- zstd function tests
SELECT zstd(NULL) AS zstd_null;
 zstd_null 
-----------
 
(1 row)

SELECT zstd('') AS zstd_blank;
 zstd_blank 
------------
 \x
(1 row)

SELECT zstd('\x00'::bytea) AS zstd_zero;
       zstd_zero        
------------------------
 \x28b52ffd200109000000
(1 row)

